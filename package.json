{
  "name": "ai-debate-arena",
  "version": "1.0.0",
  "description": "AI models debate each other to find the best answer — an Electron + React app where ChatGPT, Gemini, DeepSeek, and Perplexity battle it out",
  "main": "main.js",
  "author": {
    "name": "Raj Thakur",
    "url": "https://github.com/thakur-raj"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thakur-raj/ai-debate-arena.git"
  },
  "license": "MIT",
  "keywords": [
    "ai",
    "debate",
    "chatgpt",
    "gemini",
    "deepseek",
    "perplexity",
    "electron",
    "react",
    "llm"
  ],
  "scripts": {
    "dev": "concurrently -k \"vite --port 5173\" \"wait-on http://localhost:5173 && cross-env VITE_PORT=5173 electron .\"",
    "build": "vite build",
    "start": "electron .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.{js,jsx}' 'main.js' 'preload.js'",
    "lint:fix": "eslint 'src/**/*.{js,jsx}' 'main.js' 'preload.js' --fix",
    "build:electron": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win",
    "build:mac": "vite build && electron-builder --mac",
    "build:linux": "vite build && electron-builder --linux",
    "publish": "vite build && electron-builder --publish always"
  },
  "build": {
    "appId": "com.thakur-raj.ai-debate-arena",
    "productName": "AI Debate Arena",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "assets/icon.ico",
      "artifactName": "AI-Debate-Arena-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.ico",
      "category": "Utility"
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.0.2",
    "png2icons": "^2.0.1",
    "vite": "^5.1.0",
    "vitest": "^4.1.4",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
