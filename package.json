    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^8.2.0",
    "electron": "^29.0.0",
    "jsdom": "^29.0.2",
    "vite": "^5.1.0",
    "vitest": "^4.1.4",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
